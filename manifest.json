{
  "manifest_version": 3,
  "name": "Reader Tracker",
  "version": "1.1",
  "description": "Turn headings into checkboxes and track reading progress with collapsible sections",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
